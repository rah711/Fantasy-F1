# Virtual environment
.venv/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# FastF1 cache (large binary files)
data/cache/

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store

# IDE
.vscode/
.idea/

# Data files
# Raw Kaggle CSVs + tracing archive are small (~360KB) and committed so the
# scheduled retrain on GitHub Actions can rebuild sessions.parquet from
# scratch. Tracing insights per-year CSVs (DOTD, pitstops) stay ignored —
# usually empty or supplied per workflow.
data/raw/tracing_insights/**/*.csv
data/raw/kaggle/*.zip

# Processed data (regenerated from raw)
data/processed/*.parquet
data/processed/models/
data/processed/backtest/
data/processed/optimizer_reports*/
data/processed/optimizer_tuning*/
data/processed/predictions/

# ...but commit the production model artifacts so the deployed app can
# load them without needing to re-run the pipeline (Streamlit Cloud has
# an ephemeral filesystem + no access to the raw data sources). Refresh
# these locally with `python scripts/retrain.py` and commit the diff.
!data/processed/features.parquet
!data/processed/circuit_stats.json
!data/processed/models/
data/processed/models/*
!data/processed/models/fantasy_model.joblib
!data/processed/models/feature_names.txt
!data/processed/models/backtest/
data/processed/models/backtest/*
!data/processed/models/backtest/walk_forward_2025_predictions.parquet

# OpenF1 enrichment cache
data/cache/

# (data/raw/tracing_archive/ — committed; small parquets the pipeline uses
# as the historical bulk source. Not regenerated, just versioned.)

# Notebook caches
notebooks/.cache/

# Streamlit secrets (never commit)
.streamlit/secrets.toml

# Claude local settings
.claude/settings.local.json
.claude/launch.json

# User-supplied fantasy tables (optional — commit if you want version history)
# data/fantasy/
